{
  "name": "snacksafari-server",
  "version": "1.0.0",
  "description": "SnackSafari backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint \"src/**/*.js\"",
    "test": "vitest run",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node src/seed.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "vitest": "^2.1.8"
  }
}
